{
  "manifest_version": 3,
  "name": "SignSafe",
  "version": "0.1.0",
  "description": "Understand any Solana transaction before you sign it.",
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "<all_urls>",
    "https://api.mainnet-beta.solana.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "SignSafe"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "page_hook.js",
        "overlay.html",
        "overlay.css",
        "overlay.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
