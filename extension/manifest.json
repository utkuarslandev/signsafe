{
  "manifest_version": 3,
  "name": "SignSafe",
  "version": "0.1.0",
  "description": "Understand any Solana transaction before you sign it.",
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "https://api.devnet.solana.com/*",
    "https://api.mainnet-beta.solana.com/*",
    "https://api.signsafe.xyz/*"
  ],
  "background": {
    "service_worker": "src/background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["shared/constants.js", "src/content/overlay-session.js", "src/content/content-script.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "SignSafe",
    "default_icon": {
      "16": "icons/icon16.png",
      "24": "icons/icon24.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": [
        "shared/constants.js",
        "shared/demo-fixtures.js",
        "shared/page-helpers.js",
        "shared/overlay-helpers.js",
        "src/page/page-hook.js",
        "overlay.html",
        "overlay.css",
        "src/overlay/overlay.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
